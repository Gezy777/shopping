{{ define "header"}}
<!doctype html>
  <html lang="en">

    <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1">

      {{if $.redirect}}
        <meta http-equiv="refresh" content="5;url=/checkout/result"/>
      {{end}}

      <title>Hot Sales | CloudWeGo</title>
      <link href="/static/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer"/>
    </head>

    <body class="min-vh-100">

      <header>
        <nav class="navbar navbar-expand-lg bg-body-tertiary">
          <div class="container-fluid">

            <img class="navbar-brand" href="#" src="/static/image/barca.webp" alt="CloudWeGo" style="height: 3em"/>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
              
              <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                
                <li class="nav-item">
                  <a class="nav-link active" aria-current="page" href="/">Home</a>
                </li>

                <li class="nav-item dropdown">

                  <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Categories
                  </a>

                  <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="/category/t-shirt">T-shirt</a></li>
                    <li><a class="dropdown-item" href="/category/sticker">Sticker</a></li>
                  </ul>

                </li>
                <form action="/about" method="post">
                    <div class="ms-3">
                      <button type="submit" class="btn">About</button>
                    </div>
                  </form>
              </ul>

              <form class="d-flex ms-auto" role="search" action="/search" method="get">
                  <input class="form-control me-2" type="search" name="q" placeholder="Search"
                          aria-label="Search" value="{{ .q }}">
                  <button class="btn btn-outline-success" type="submit">Search</button>
              </form>
              <div class="ms-3">
                <a href="/cart" class="text-reset">
                  <i class="fa-solid fa-cart-shopping fa-xl"></i>
                </a>
              </div>

              {{if .user_id}}
              <div class="ms-3">
                <i class="fa-solid fa-user fa-xl"></i>
              </div>
              <form action="/auth/logout" method="post">
                <div class="ms-3">
                  <button type="submit" class="btn btn-primary">Log Out</button>
                </div>
              </form>
              <div class="d-flex justify-content-center">
                <a href="/order" class="btn btn-info">Check Order</a>
            </div>
              {{else}}
              <div class="ms-3">
                <a type="button" class="btn btn-primary" href="/sign-in">Sign In</a>
              </div>
              {{end}}
              
            </div>
          </div>
        </nav>
        <script src="/static/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
      </header>

      <main>
        <div class="container-fluid">
{{end}}